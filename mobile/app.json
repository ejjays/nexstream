{
  "expo": {
    "name": "Panther",
    "slug": "cyan-phanter",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "assets/*.png",
      "assets/*.webp",
      "assets/*.mp4",
      "assets/*.lottie",
      "assets/fonts/*"
    ],
    "android": {
      "package": "com.nexstream.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-status-bar",
      "expo-sharing",
      "expo-font",
      "expo-image",
      "@react-native-firebase/app",
      "./plugins/withNotificationIcon",
      "./plugins/withLargeHeap",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "react-native-video",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow Panther to save downloads to your gallery.",
          "photosPermission": "Allow Panther to access your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Panther to attach photos to your comments."
        }
      ],
      [
        "@nikhil-cephei/ffmpeg-kit-react-native",
        {
          "subspec": "full-gpl"
        }
      ],
      [
        "react-native-notify-kit",
        {
          "android": {
            "foregroundService": {
              "types": [
                "dataSync"
              ]
            }
          }
        }
      ],
      [
        "react-native-nitro-google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.placeholder-android-only"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "53a37ed1-aeda-4cf4-81de-18ba7e1e40a9"
      }
    }
  }
}
