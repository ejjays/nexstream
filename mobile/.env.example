# every var OPTIONAL — app builds & downloads with empty .env.
# each just unlocks a feature. all EXPO_PUBLIC_* = bundled into the
# APK (anyone can read), so only ship values safe to be public.

# ── safe to expose (public by design) ──

# sentry crash reporting. DSN public. blank = off.
EXPO_PUBLIC_SENTRY_DSN=

# updates tab (reactions + comments). anon key public, RLS-guarded.
# blank = tab "not configured". see supabase/schema.sql
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# native google sign-in (updates tab). WEB oauth client id, public.
# add same id in supabase -> auth -> providers -> google.
# blank = sign-in fails, so the updates tab is read-only (no react/comment).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# edge registry — skips resolution race for known tracks. token MUST
# be read-only (ships public). blank = registry off.
EXPO_PUBLIC_TURSO_URL=
EXPO_PUBLIC_TURSO_READ_TOKEN=

# giphy GIF picker in comments. free API key from the GIPHY developer
# dashboard (public, rate-limited). blank = GIF button hidden.
# get one: https://developers.giphy.com/dashboard/
EXPO_PUBLIC_GIPHY_KEY=

# flag, no secret. 1 = bypass in-memory resolve cache.
EXPO_PUBLIC_DISABLE_FAST_RESOLVE=

# ── personal build only — never ship in a public release ──
# your own creds; bundled = anyone can extract & abuse.

# youtube session cookie — authenticates extraction, stops "not a
# bot"/403. blank = anonymous (potoken). your login — never ship.
EXPO_PUBLIC_YT_COOKIE=

# bilibili cookie — unlocks 1080p+ (login-gated). blank = lower res.
# your login — never ship.
EXPO_PUBLIC_BILIBILI_COOKIE=

# ── spotify: configured SERVER-SIDE, not here ──
# secret lives in the spotify-token supabase edge function, so it never
# ships in the APK. needs a premium spotify dev account (2026). set + deploy:
#   supabase secrets set SPOTIFY_CLIENT_ID=xxx SPOTIFY_CLIENT_SECRET=yyy
#   supabase functions deploy spotify-token
# not deployed = spotify resolves via other sources (works, less precise).
