        <Route
          path="/guide/stack"
          element={<Navigate to="/resources/stack" replace />}
        />
        <Route
          path="/docs/story"
          element={<Navigate to="/resources/story" replace />}
        />
        <Route
          path="/docs/architecture"
          element={<Navigate to="/resources/architecture" replace />}
        />
