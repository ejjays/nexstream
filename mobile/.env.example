# bilibili.tv cookie to unlock 1080p+ (login-gated)
EXPO_PUBLIC_BILIBILI_COOKIE=

# set to 1 to bypass the in-memory resolve cache
EXPO_PUBLIC_DISABLE_FAST_RESOLVE=

# spotify (client-credentials flow) — on-device spotify track resolution.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=

# optional youtube account cookie (the Cookie header string from a logged-in
# youtube session). authenticates extraction so a rate-limited/flagged IP stops
# getting "confirm you're not a bot" / 403 on stream downloads — same idea as
# yt-dlp --cookies. SECURITY: EXPO_PUBLIC vars are bundled into the app, so this
# is your own account's cookie in your own build — never commit it or ship it.
# blank = anonymous (uses a generated potoken instead).
EXPO_PUBLIC_YT_COOKIE=

# sentry crash reporting — DSN is safe to expose in clients. blank = disabled.
EXPO_PUBLIC_SENTRY_DSN=

# supabase (updates tab: reactions + comments). anon key is safe to expose.
# blank = updates tab shows a "not configured" state. see supabase/schema.sql
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# shared edge registry (read-only): lets a known spotify->youtube mapping
# skip the resolution race. points at the backend's turso db.
# SECURITY: EXPO_PUBLIC vars are bundled into the app, so this token is
# public — it MUST be a READ-ONLY token (turso db tokens create <db> --read-only).
# blank = registry disabled, resolution falls back to the normal race.
EXPO_PUBLIC_TURSO_URL=
EXPO_PUBLIC_TURSO_READ_TOKEN=

# native google sign-in for the updates tab. WEB oauth client id from google
# cloud console (credentials -> oauth client -> web application). add this same
# id in supabase dashboard -> authentication -> providers -> google too.
# safe to expose (EXPO_PUBLIC is bundled). blank = google button errors on tap.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=