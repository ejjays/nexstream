exports.proxyStream = async (req, res) => {
  let { targetUrl, formatId, url: rawFallbackUrl, filename } = req.query;
  if (Array.isArray(targetUrl)) targetUrl = targetUrl[0];
  if (Array.isArray(formatId)) formatId = formatId[0];
