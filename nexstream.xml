      currentSrc !== lastSrcRef.current
    ) {
      lastSrcRef.current = currentSrc;
      setIsPlaying(false);
    }
  }, [videoData?.previewUrl, videoData?.spotifyMetadata?.previewUrl, isOpen]);
  useEffect(() => {
    setOptions(getSpotifyOptions(videoData));
  }, [videoData]);
  useEffect(() => {
