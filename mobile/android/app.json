{
  "expo": {
    "name": "NexStream",
    "slug": "nexstream-android",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.nexstream.android",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#030014"
      }
    },
    "plugins": [
      "expo-status-bar",
      "expo-sharing",
      "expo-font",
      "expo-image",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#030014"
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow NexStream to save downloads to your gallery.",
          "photosPermission": "Allow NexStream to access your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      ["@nikhil-cephei/ffmpeg-kit-react-native", { "subspec": "full-gpl" }]
    ],
    "extra": {
      "eas": {
        "projectId": "00ebf356-bb27-400e-afa0-61315fc32de8"
      }
    },
    "owner": "ejjay"
  }
}
