{
  "expo": {
    "name": "NexStream",
    "slug": "nexstream-android",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/00ebf356-bb27-400e-afa0-61315fc32de8"
    },
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.nexstream.android",
      "permissions": [
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030014"
      }
    },
    "plugins": [
      "expo-status-bar",
      "expo-sharing",
      "expo-font",
      "expo-image",
      "./plugins/withNotificationIcon",
      "./plugins/withLargeHeap",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#030014"
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Allow NexStream to save downloads to your gallery.",
          "photosPermission": "Allow NexStream to access your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "@nikhil-cephei/ffmpeg-kit-react-native",
        {
          "subspec": "full-gpl"
        }
      ],
      [
        "react-native-notify-kit",
        {
          "android": {
            "foregroundService": {
              "types": ["dataSync"]
            }
          }
        }
      ],
      [
        "react-native-nitro-google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.placeholder-android-only"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "00ebf356-bb27-400e-afa0-61315fc32de8"
      }
    },
    "owner": "ejjay"
  }
}
