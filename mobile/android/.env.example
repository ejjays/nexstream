# bilibili.tv cookie to unlock 1080p+ (login-gated)
EXPO_PUBLIC_BILIBILI_COOKIE=

# set to 1 to bypass the in-memory resolve cache
EXPO_PUBLIC_DISABLE_FAST_RESOLVE=

# spotify (client-credentials flow) — on-device spotify track resolution.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=
